ANTHROPIC_API_KEY=sk-ant-...
# model for comment drafting (claude-sonnet-4-6 = cost-effective; claude-opus-4-8 = strongest)
ANTHROPIC_MODEL=claude-sonnet-4-6
# feed to scrape; override with a hashtag feed if your home feed is sparse
# e.g. FEED_URL=https://www.linkedin.com/feed/hashtag/python/
FEED_URL=https://www.linkedin.com/feed/
# comma-separated topics used by the "interesting" scorer
INTERESTS=python,backend,fastapi,postgres,ai,llm,rag,agents,aws
# one-line bio the comment ghost-writer speaks from
PERSONA=Senior backend Python engineer (FastAPI, PostgreSQL, AWS), building LLM agent systems.
# 1 = score/print but never click Like
DRY_RUN=0
# 0 = stop at Level 2 (no profile visits)
PROFILE_AWARE=1
TOP_N=5
COMMENT_N=3
